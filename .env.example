# Zarvis Environment Configuration Template
# Rename this file to .env and fill in your credentials

# Google Gemini API Key
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Personal Information for Integration
LEETCODE_USERNAME=your_leetcode_username
GITHUB_USERNAME=your_github_username

# Optional: HuggingFace (Fallback)
HUGGINGFACE_EMAIL=your_email
HUGGINGFACE_PASSWORD=your_password
